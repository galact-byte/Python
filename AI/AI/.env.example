# 复制此文件为 .env 并填入你的实际值
# cp .env.example .env

# 代理地址
PROXY=127.0.0.1:7890

# 邮箱 API Key
MAIL_API_KEY=your_mail_api_key_here

# CLIProxyAPI auth目录（默认自动识别，一般不需要改）
# 默认值等同于 %USERPROFILE%\.cli-proxy-api（Windows）或 ~/.cli-proxy-api（Mac/Linux）
# 如需自定义才填这行，否则删掉即可
# CPA_AUTH_DIR=C:/Users/你的用户名/.cli-proxy-api

# 结果备份文件（合并模式时使用）
OUTPUT_FILE=accounts.json
